# Perfil Spring (use "docker" na Railway)
SPRING_PROFILES_ACTIVE=docker

# PostgreSQL — local via docker compose
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/escola_remo
SPRING_DATASOURCE_USERNAME=escola
SPRING_DATASOURCE_PASSWORD=escola123

# Na Railway, use as variáveis do plugin PostgreSQL:
# SPRING_DATASOURCE_URL=jdbc:postgresql://${PGHOST}:${PGPORT}/${PGDATABASE}
# SPRING_DATASOURCE_USERNAME=${PGUSER}
# SPRING_DATASOURCE_PASSWORD=${PGPASSWORD}

# Porta (Railway injeta PORT automaticamente)
# PORT=8080

# CORS — origens permitidas, separadas por vírgula
APP_CORS_ORIGINS=http://localhost:3000,https://seu-app.vercel.app

# Seed de dados demo (só roda se o banco estiver vazio)
APP_SEED_ENABLED=true

# Diretório de uploads de imagens
APP_UPLOADS_DIR=/app/uploads

# Fuso horário
TZ=America/Sao_Paulo
