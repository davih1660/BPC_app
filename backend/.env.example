# Perfil Spring (use "docker" na Railway)
SPRING_PROFILES_ACTIVE=docker

# PostgreSQL local via docker compose (PGHOST padrão: postgres)
# Na Railway: conecte o serviço Postgres via Add Reference — injeta PGHOST, PGPORT, etc.
# NÃO defina SPRING_DATASOURCE_URL na Railway (conflita com o perfil docker).

# CORS — origens permitidas, separadas por vírgula
APP_CORS_ORIGINS=http://localhost:3000,https://seu-app.vercel.app

# Seed de dados demo (só roda se o banco estiver vazio)
APP_SEED_ENABLED=true

# Diretório de uploads de imagens
APP_UPLOADS_DIR=/app/uploads

# SSL do Postgres (require na Railway; disable só em rede privada local)
POSTGRES_SSLMODE=require

# Fuso horário
TZ=America/Sao_Paulo
